APP_NAME=ppt-master-service
APP_HOST=0.0.0.0
APP_PORT=8099

# Shared service auth
SERVICE_API_KEY=change-me
PUBLIC_BASE_URL=https://ppt.example.com

# Storage
STORAGE_DIR=./storage
EXPORT_RETENTION_DAYS=7
MAX_UPLOAD_MB=50
JOB_POLL_INTERVAL_SECONDS=3

# Point this at the local checkout of hugohe3/ppt-master
PPT_MASTER_REPO_ROOT=/opt/ppt-master

# OpenAI-compatible model endpoint used by the worker
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-xxxx
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=180
LLM_TEMPERATURE=0.2
LOG_LLM_PROMPTS=false

# Defaults for jobs
DEFAULT_CANVAS_FORMAT=ppt169
DEFAULT_PAGE_COUNT=8
DEFAULT_STYLE_OBJECTIVE=general_consulting
DEFAULT_IMAGE_STRATEGY=placeholder
DEFAULT_ICON_STYLE=tabler-outline
